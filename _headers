# Cloudflare Pages headers — translated from netlify.toml
# Order matters: more specific rules first, then global.

/*.jsx
  Content-Type: application/javascript; charset=utf-8
  Cache-Control: public, max-age=300, must-revalidate

/*.js
  Cache-Control: public, max-age=300, must-revalidate

/*.css
  Cache-Control: public, max-age=300, must-revalidate

/build/*
  Cache-Control: public, max-age=300, must-revalidate

/cart-store.js
  Cache-Control: public, max-age=300, must-revalidate

/uploads/*
  Cache-Control: public, max-age=31536000, immutable

/index.html
  Cache-Control: public, max-age=0, must-revalidate

/cart.html
  Cache-Control: public, max-age=0, must-revalidate

/checkout.html
  Cache-Control: public, max-age=0, must-revalidate

/404.html
  Cache-Control: public, max-age=3600

/favicon.ico
  Cache-Control: public, max-age=604800

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self' https: data: blob: 'unsafe-inline' 'unsafe-eval'; object-src 'none'; base-uri 'self'; frame-ancestors 'self'; form-action 'self' https://formsubmit.co https://nu2vqa-ma.myshopify.com
